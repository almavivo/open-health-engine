{
  "name": "@almavivo/engine",
  "version": "0.2.0",
  "description": "Open, deterministic clinical rules engine: supplement, lab, medication-review, and physical-prep guidance with public exclusion lists and named-guideline anchors.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/almavivo/open-health-engine",
  "repository": {
    "type": "git",
    "url": "https://github.com/almavivo/open-health-engine.git"
  },
  "bugs": {
    "url": "https://github.com/almavivo/open-health-engine/issues"
  },
  "keywords": [
    "supplement",
    "clinical-decision-support",
    "rules-engine",
    "evidence-based",
    "health",
    "nutrition",
    "lab-recommendations",
    "lab-interpretation",
    "medication-review",
    "physical-prep",
    "circadian",
    "nice-guidelines"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "MEDICAL-DISCLAIMER.md",
    "CONTRIBUTING.md",
    "docs"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:generate": "tsx scripts/generate-docs.ts",
    "docs:check": "tsx scripts/generate-docs.ts && git diff --exit-code -- docs/supplements docs/labs && test -z \"$(git status --porcelain -- docs/supplements docs/labs)\"",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "fast-check": "^4.7.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
